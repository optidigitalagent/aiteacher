# Copy this file to backend/.env and fill in real values.
# backend/.env is what the server reads — NOT the root .env file.

# === AI APIs ===
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# Demo lesson AI (cheap model — keeps 100 demos <= $5 total)
OPENAI_DEMO_MODEL=gpt-4.1-mini
OPENAI_TRANSLATE_MODEL=gpt-4.1-mini
DEMO_AI_MAX_CALLS=8
DEMO_AI_MAX_INPUT_TOKENS_PER_CALL=900
DEMO_AI_MAX_OUTPUT_TOKENS_PER_CALL=220
DEMO_AI_MAX_ESTIMATED_COST_USD=0.05
DEEPGRAM_API_KEY=...
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Demo voice/TTS — OpenAI TTS (~$15/1M chars, gpt-4o-mini-tts is cheaper)
# 1600 chars/demo × $15/1M = $0.000024 — negligible vs AI text cost (~$0.008)
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
DEMO_TTS_MAX_CHARS_PER_SESSION=1600
DEMO_TTS_MAX_CALLS_PER_SESSION=6
# Full allowed list — remove types here to mute specific messages (cost control)
DEMO_TTS_ALLOWED_MESSAGE_TYPES=greeting,main_prompt,follow_up_question,key_correction,speaking_feedback,writing_feedback,final_result
DEMO_TTS_CACHE_ENABLED=true

# === Vector DB ===
PINECONE_API_KEY=...
PINECONE_INDEX=ai-teacher-textbooks

# === Database ===
DATABASE_URL=postgres://aiteacher:aiteacher_dev@localhost:5432/aiteacher
REDIS_URL=redis://localhost:6379

# === Auth ===
JWT_SECRET=change-me-in-production-use-32-chars-min

# === Google OAuth ===
# 1. Go to https://console.cloud.google.com/ → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add Authorised redirect URI: http://localhost:4000/auth/google/callback
# 4. Paste the values below
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
# Comma-separated extra origins allowed by CORS (dev/QA only).
# Example: CORS_EXTRA_ORIGINS=http://localhost:3000
# Leave empty in production — FRONTEND_URL is the only permitted origin there.
CORS_EXTRA_ORIGINS=

# === Server ===
PORT=4000
NODE_ENV=development
ANTHROPIC_API_KEY=sk-ant-...

# === LiqPay Payment ===
LIQPAY_PUBLIC_KEY=sandbox_...
LIQPAY_PRIVATE_KEY=sandbox_...
LIQPAY_CURRENCY=UAH
# Set to 1 for sandbox/test mode, 0 for production
LIQPAY_SANDBOX=1
# Where LiqPay redirects the user after payment (frontend success page)
LIQPAY_RESULT_URL=https://yourdomain.com/pricing/success
# LiqPay server-to-server callback URL (must be publicly reachable)
LIQPAY_SERVER_URL=https://yourdomain.com/billing/liqpay/callback

# === Paid Plan Config ===
PAID_PLAN_ID=monthly_10_lessons
PAID_PLAN_NAME=AI Teacher Monthly
PAID_PLAN_PRICE_UAH=1
PAID_PLAN_LESSONS_LIMIT=10
PAID_PLAN_LESSON_MINUTES=50
PAID_PLAN_TOTAL_MINUTES=500
PAID_PLAN_DURATION_DAYS=31

# === Dev / QA Billing ===
# Set to 1 to enable POST /billing/activate (mock subscription activation for tests).
# NEVER set to 1 in a production environment with real user traffic.
ENABLE_MOCK_BILLING=0
