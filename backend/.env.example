# Copy this file to backend/.env and fill in real values.
# backend/.env is what the server reads — NOT the root .env file.

# === AI APIs ===
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# Demo lesson AI (cheap model — keeps 100 demos <= $5 total)
OPENAI_DEMO_MODEL=gpt-4.1-mini
OPENAI_TRANSLATE_MODEL=gpt-4.1-mini
DEMO_AI_MAX_CALLS=8
DEMO_AI_MAX_INPUT_TOKENS_PER_CALL=900
DEMO_AI_MAX_OUTPUT_TOKENS_PER_CALL=220
DEMO_AI_MAX_ESTIMATED_COST_USD=0.05
DEEPGRAM_API_KEY=...
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# TTS provider selection: auto (ElevenLabs first, OpenAI fallback) | openai | elevenlabs
# Set TTS_PROVIDER=openai to skip ElevenLabs entirely (e.g. if ElevenLabs key is unavailable).
# Set TTS_PROVIDER=elevenlabs to skip OpenAI (use only when ElevenLabs key is valid).
TTS_PROVIDER=auto
# OpenAI TTS model — tts-1 ($15/1M chars) or gpt-4o-mini-tts (cheaper, same quality for kids)
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova
DEMO_TTS_MAX_CHARS_PER_SESSION=1600
DEMO_TTS_MAX_CALLS_PER_SESSION=6
# Full allowed list — remove types here to mute specific messages (cost control)
DEMO_TTS_ALLOWED_MESSAGE_TYPES=greeting,main_prompt,follow_up_question,key_correction,speaking_feedback,writing_feedback,final_result
DEMO_TTS_CACHE_ENABLED=true

# === Vector DB ===
PINECONE_API_KEY=...
PINECONE_INDEX=ai-teacher-textbooks

# === Database ===
DATABASE_URL=postgres://aiteacher:aiteacher_dev@localhost:5432/aiteacher
REDIS_URL=redis://localhost:6379

# === Auth ===
JWT_SECRET=change-me-in-production-use-32-chars-min

# === Google OAuth ===
# 1. Go to https://console.cloud.google.com/ → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add Authorised redirect URI: http://localhost:4000/auth/google/callback
# 4. Paste the values below
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
# Comma-separated extra origins allowed by CORS (dev/QA only).
# Example: CORS_EXTRA_ORIGINS=http://localhost:3000
# Leave empty in production — FRONTEND_URL is the only permitted origin there.
CORS_EXTRA_ORIGINS=

# === Server ===
PORT=4000
NODE_ENV=development
ANTHROPIC_API_KEY=sk-ant-...

# === Telegram Bot Integration ===
# URL of the deployed Telegram bot service (Railway)
TELEGRAM_BOT_SERVICE_URL=https://mentium-tg-bot-production.up.railway.app
# Shared secret between platform backend and bot service — NEVER expose to frontend
INTERNAL_TELEGRAM_API_KEY=your-internal-telegram-api-key-here

# === LiqPay Payment ===
LIQPAY_PUBLIC_KEY=sandbox_...
LIQPAY_PRIVATE_KEY=sandbox_...
LIQPAY_CURRENCY=UAH
# Set to 1 for sandbox/test mode, 0 for production
LIQPAY_SANDBOX=1
# Where LiqPay redirects the user after payment (frontend success page)
LIQPAY_RESULT_URL=https://yourdomain.com/pricing/success
# LiqPay server-to-server callback URL (must be publicly reachable)
LIQPAY_SERVER_URL=https://yourdomain.com/billing/liqpay/callback

# === Paid Plan Config ===
PAID_PLAN_ID=monthly_10_lessons
PAID_PLAN_NAME=AI Teacher Monthly
PAID_PLAN_PRICE_UAH=1
PAID_PLAN_LESSONS_LIMIT=10
PAID_PLAN_LESSON_MINUTES=50
PAID_PLAN_TOTAL_MINUTES=500
PAID_PLAN_DURATION_DAYS=31

# === Dev / QA Billing ===
# Set to 1 to enable POST /billing/activate (mock subscription activation for tests).
# NEVER set to 1 in a production environment with real user traffic.
ENABLE_MOCK_BILLING=0

# === Kids Brain v1 Runtime Caps ===
# Caps for the Kids Brain v1 session runtime. All are finite; never set to 0 or unlimited.
# Defaults (if unset) allow a full 10-exercise Kid's Box lesson to complete:
#   KIDS_MAX_LLM_CALLS=60        (10 exercises × up to 4 turns + headroom)
#   KIDS_MAX_TTS_CHARS=8000      (~80 teacher utterances × 100 chars avg)
#   KIDS_MAX_DURATION_MINUTES=20 (matches AAA guideline for 6-9 year-olds)
# Invalid values (non-integer, 0, negative) fall back to the safe defaults above.
KIDS_MAX_LLM_CALLS=60
KIDS_MAX_TTS_CHARS=8000
KIDS_MAX_DURATION_MINUTES=20

# === Kids Personalization V2 Feature Flags ===
# Template-only personalization layered on top of the authoritative Kid's Box
# curriculum. Each flag must be the exact string 'true' to enable; anything else
# (unset/empty/'1'/'TRUE') = OFF. Curriculum, scoring, target words, and
# escalation are NEVER affected — only how the teacher TALKS.
# Roll out one at a time: enable KIDS_PERSONALIZATION_V2 (master) first, verify
# production logs, then enable per-tier flags individually. Roll back = set OFF.
# ALL DEFAULT OFF.
KIDS_PERSONALIZATION_V2=
KIDS_WARMUP_ENABLED=
KIDS_INTEREST_EXAMPLES_V2=
KIDS_INTEREST_PRAISE=
KIDS_INTEREST_RECOVERY_V2=
KIDS_MICRO_DIALOGUE_ENABLED=
KIDS_TEACHER_PERSONA_V2=

# === Runtime Observability ===
# Set to 1 to emit structured RUNTIME_TRACE JSON lines to stderr.
# Off by default — safe to enable in staging/QA for debugging lesson flows.
# NEVER enable in production unless log volume is budgeted (1 line per turn).
ENABLE_RUNTIME_TRACE=0
