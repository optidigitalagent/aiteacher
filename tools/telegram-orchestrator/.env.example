# Telegram Bot API token from BotFather. Never commit the real value.
TELEGRAM_BOT_TOKEN=

# Shared secret used by the platform backend and Codex tooling to call this bot.
INTERNAL_TELEGRAM_API_KEY=

# Required when TELEGRAM_BOT_TOKEN is set unless
# ORCHESTRATOR_ALLOW_ALL_CHATS_FOR_DEV=1 is set for local-only testing.
ORCHESTRATOR_ALLOWED_CHAT_IDS=
ORCHESTRATOR_ALLOW_ALL_CHATS_FOR_DEV=0

# HTTP port for Railway/local.
PORT=4010

# Storage path for generated goal packets.
ORCHESTRATOR_DATA_DIR=./data

# Display name shown by /start.
ORCHESTRATOR_BOT_NAME=Codex Intake Bot

# Keep platform account linking off for standalone/local bots.
ORCHESTRATOR_PLATFORM_LINK_ENABLED=0
