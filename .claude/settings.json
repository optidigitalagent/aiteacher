{
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(railway logs *)",
      "Bash(railway variables)",
      "Bash(railway up)",
      "Bash(railway run *)",
      "Bash(railway status)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(railway delete *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)"
    ]
  }
}
